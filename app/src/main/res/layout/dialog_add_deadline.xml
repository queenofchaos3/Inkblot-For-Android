<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/bg_card">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Deadline"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <EditText
        android:id="@+id/et_deadline_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. Submit to magazine"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_muted"
        android:textSize="15sp"
        android:background="@color/bg_dark"
        android:padding="12dp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btn_pick_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pick a date"
        android:backgroundTint="@color/bg_dark"
        android:textColor="@color/accent_blue"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_selected_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/text_muted"
        android:textSize="13sp"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_cancel_deadline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cancel"
            android:backgroundTint="@color/bg_dark"
            android:textColor="@color/text_muted"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btn_save_deadline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Save"
            android:backgroundTint="@color/accent_blue"
            android:textColor="@color/white"/>

    </LinearLayout>

</LinearLayout>